# ── Base de datos ──
DATABASE_URL=                    # connection string Postgres (pooled, para runtime)
DIRECT_URL=                      # connection string directa, para migraciones Prisma

# ── Auth.js ──
AUTH_SECRET=                     # secret para firmar sesiones/JWT
NEXTAUTH_URL=                    # URL base de la app (http://localhost:3000 en dev)

# ── Vercel Blob ──
BLOB_READ_WRITE_TOKEN=           # token de storage para adjuntos (imagenes en soluciones/notebook)

# ── App ──
NODE_ENV=                        # development | production
NEXT_PUBLIC_APP_URL=              # URL publica, usada en el link de invitacion generado por el admin
